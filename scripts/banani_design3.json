      "screenName": "Jamrock Homepage",
      "html": "<head>\n<style id=\"global-styles\">\n  :root {\n    --background: #FFFFFF;\n    --foreground: #1A1A1A;\n    --muted: #F6F6F6;\n  }\n  * {\n    box-sizing: border-box;\n    margin: 0;\n    padding: 0;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    border-radius: 0 !important;\n    box-shadow: none !important;\n  }\n  body {\n    background-color: var(--background);\n    color: var(--foreground);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n  img {\n    display: block;\n    max-width: 100%;\n  }\n</style>\n<style id=\"header-styles\">\n  .promo-bar {\n    position: sticky;\n    top: 0;\n    z-index: 100;\n    background-color: var(--foreground);\n    color: var(--background);\n    text-align: center;\n    padding: 14px;\n    font-size: 11px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    font-weight: 700;\n  }\n  .header {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    align-items: center;\n    padding: 0 60px;\n    background-color: var(--background);\n  }\n  .nav-left {\n    display: flex;\n    gap: 48px;\n  }\n  .nav-link {\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 1.5px;\n    font-weight: 700;\n    color: var(--foreground);\n    text-decoration: none;\n    cursor: pointer;\n  }\n  .logo-center {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 64px 0; /* Massive top and bottom padding */\n  }\n  .logo-center img {\n    height: 56px;\n    object-fit: contain;\n  }\n  .nav-right {\n    display: flex;\n    gap: 32px;\n    justify-content: flex-end;\n  }\n</style>\n<style id=\"hero-styles\">\n  .hero-section {\n    position: relative;\n    width: 100%;\n    height: 85vh;\n    background-color: #000;\n    overflow: hidden;\n  }\n  .hero-bg {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    opacity: 0.75;\n  }\n  .hero-content {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    padding: 24px;\n  }\n  .hero-title {\n    font-size: 64px;\n    font-weight: 500;\n    text-transform: uppercase;\n    letter-spacing: 4px;\n    color: var(--background);\n    margin-bottom: 40px;\n    line-height: 1.1;\n  }\n  .hero-cta {\n    background-color: var(--background);\n    color: var(--foreground);\n    padding: 20px 64px;\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 2px;\n    font-weight: 700;\n    border: none;\n    cursor: pointer;\n  }\n</style>\n<style id=\"products-styles\">\n  .products-section {\n    background-color: var(--muted);\n    padding: 160px 60px;\n  }\n  .products-title {\n    text-align: center;\n    font-size: 24px;\n    text-transform: uppercase;\n    letter-spacing: 8px;\n    font-weight: 800;\n    margin-bottom: 100px;\n    color: var(--foreground);\n  }\n  .product-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 48px;\n  }\n  .product-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    cursor: pointer;\n  }\n  .product-image-container {\n    width: 100%;\n    aspect-ratio: 3/4;\n    overflow: hidden;\n    margin-bottom: 32px;\n  }\n  .product-image-container img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n  .product-title {\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    font-weight: 700;\n    margin-bottom: 10px;\n  }\n  .product-price {\n    font-size: 14px;\n    font-weight: 500;\n    color: #444444;\n    letter-spacing: 0.5px;\n  }\n</style>\n<style id=\"editorial-styles\">\n  .editorial-section {\n    position: relative;\n    width: 100%;\n    height: 100vh;\n    background-color: #000;\n    overflow: hidden;\n  }\n  .editorial-bg {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    opacity: 0.7;\n  }\n  .editorial-content {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    padding: 120px 60px;\n  }\n  .editorial-manifesto {\n    color: var(--background);\n    font-size: 68px;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: -2px;\n    line-height: 0.95;\n    max-width: 1000px;\n  }\n  .editorial-sub {\n    color: var(--background);\n    font-size: 14px;\n    text-transform: uppercase;\n    letter-spacing: 3px;\n    font-weight: 600;\n    margin-top: 48px;\n    cursor: pointer;\n  }\n</style>\n</head><body>\n\n<div class=\"promo-bar\">\n  Free Shipping On All Orders\n</div>\n\n<header class=\"header\">\n  <div class=\"nav-left\">\n    <div class=\"nav-link\" data-media-type=\"banani-button\">Shop</div>\n    <div class=\"nav-link\" data-media-type=\"banani-button\">Collections</div>\n    <div class=\"nav-link\" data-media-type=\"banani-button\">Editorial</div>\n  </div>\n  <div class=\"logo-center\">\n    <img src=\"https://firebasestorage.googleapis.com/v0/b/banani-prod.appspot.com/o/reference-images%2F857c7efd-a3b5-4625-8456-99af536082ef?alt=media&amp;token=6bf50ce2-dab7-48d7-83a8-c81028e6dad1\" alt=\"Jamrock Logo\" data-media-type=\"banani-button\">\n  </div>\n  <div class=\"nav-right\">\n    <div style=\"width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; cursor: pointer;\" data-media-type=\"banani-button\">\n      <iconify-icon icon=\"lucide:search\" style=\"font-size: 24px; color: var(--foreground);\"></iconify-icon>\n    </div>\n    <div style=\"width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; cursor: pointer;\" data-media-type=\"banani-button\">\n      <iconify-icon icon=\"lucide:user\" style=\"font-size: 24px; color: var(--foreground);\"></iconify-icon>\n    </div>\n    <div style=\"width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; cursor: pointer;\" data-media-type=\"banani-button\">\n      <iconify-icon icon=\"lucide:shopping-bag\" style=\"font-size: 24px; color: var(--foreground);\"></iconify-icon>\n    </div>\n  </div>\n</header>\n\n<section class=\"hero-section\">\n  <img class=\"hero-bg\" data-aspect-ratio=\"16:9\" data-query=\"cinematic streetwear fashion editorial, high fashion, stark utilitarian lighting, pure white and black styling, hyper-detailed minimal background\" alt=\"Hero Background\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/18ab3e74-dc39-4929-9f74-ccb2c3315f38.jpg\">\n  <div class=\"hero-content\">\n    <h1 class=\"hero-title\">NUH APOLOGIES</h1>\n    <button class=\"hero-cta\" data-media-type=\"banani-button\">Explore Collection</button>\n  </div>\n</section>\n\n<section class=\"products-section\">\n  <h2 class=\"products-title\">The Artifacts</h2>\n  <div class=\"product-grid\">\n    <div class=\"product-item\" data-media-type=\"banani-button\">\n      <div class=\"product-image-container\">\n        <img data-aspect-ratio=\"3:4\" data-query=\"streetwear oversized uniform hoodie flat lay product shot on pure solid light grey background, clean aesthetic, utilitarian luxury\" alt=\"Uniform Hoodie\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/3d12d456-a291-4b3f-a086-81b96bc3fdac.jpg\">\n      </div>\n      <div class=\"product-title\">Heavyweight Uniform Hoodie</div>\n      <div class=\"product-price\">$180</div>\n    </div>\n    <div class=\"product-item\" data-media-type=\"banani-button\">\n      <div class=\"product-image-container\">\n        <img data-aspect-ratio=\"3:4\" data-query=\"technical streetwear tactical cargo pants flat lay product shot on pure solid light grey background, stark lighting, utilitarian luxury\" alt=\"Cargo Trouser\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/6b7006b2-dd7b-4631-a3f1-df163ca3f2fc.jpg\">\n      </div>\n      <div class=\"product-title\">Tactical Cargo Trouser</div>\n      <div class=\"product-price\">$240</div>\n    </div>\n    <div class=\"product-item\" data-media-type=\"banani-button\">\n      <div class=\"product-image-container\">\n        <img data-aspect-ratio=\"3:4\" data-query=\"premium oversized graphic cultural manifesto tee shirt product shot flat lay on pure solid light grey background, utilitarian luxury\" alt=\"Manifesto Tee\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/1b29633f-4272-41fc-bf20-ea167ffd1476.jpg\">\n      </div>\n      <div class=\"product-title\">Cultural Manifesto Tee</div>\n      <div class=\"product-price\">$90</div>\n    </div>\n    <div class=\"product-item\" data-media-type=\"banani-button\">\n      <div class=\"product-image-container\">\n        <img data-aspect-ratio=\"3:4\" data-query=\"utilitarian flight nylon bomber jacket streetwear product shot flat lay on pure solid light grey background, utilitarian luxury\" alt=\"Nylon Bomber\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/aeae3b2b-89da-466c-8459-7e86ac41454d.jpg\">\n      </div>\n      <div class=\"product-title\">Flight Nylon Bomber</div>\n      <div class=\"product-price\">$320</div>\n    </div>\n  </div>\n</section>\n\n<section class=\"editorial-section\">\n  <img class=\"editorial-bg\" data-aspect-ratio=\"16:9\" data-query=\"monochrome stark brutalist architecture with a solitary streetwear model standing confident, wide cinematic editorial shot, deep shadows, high contrast\" alt=\"Editorial Background\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/c4b5d7d8-d428-4524-89c4-e4a0e794fb93.jpg\">\n  <div class=\"editorial-content\">\n    <div class=\"editorial-manifesto\">IF YOU LOVE THE CULTURE.<br>WEAR THE COLOR</div>\n    <div class=\"editorial-sub\" data-media-type=\"banani-button\">Read The Manifesto →</div>\n  </div>\n</section>\n\n<script src=\"https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js\"></script>\n\n</body>",

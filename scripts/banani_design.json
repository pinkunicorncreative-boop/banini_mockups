    {
      "screenId": "KLVyWoruU0db",
      "screenName": "Jamrock Homepage",
      "html": "<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style id=\"design-tokens\">\n    :root {\n      --background: #09090b;\n      --foreground: #f4f0e6;\n      --border: #27272a;\n      --input: #18181b;\n      --primary: #f4f0e6;\n      --primary-foreground: #09090b;\n      --secondary: #18181b;\n      --secondary-foreground: #f4f0e6;\n      --muted: #27272a;\n      --muted-foreground: #a1a1aa;\n      --accent: #27272a;\n      --accent-foreground: #f4f0e6;\n      --card: #09090b;\n      --card-foreground: #f4f0e6;\n      --radius-sm: 0px;\n      --radius-md: 0px;\n      --radius-lg: 0px;\n      --radius-xl: 0px;\n      --font-family-body: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    }\n  </style>\n  <style id=\"global-styles\">\n    * {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n    body {\n      font-family: var(--font-family-body);\n      background-color: var(--background);\n      color: var(--foreground);\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n      line-height: 1.5;\n    }\n    img {\n      display: block;\n      max-width: 100%;\n    }\n    a {\n      color: inherit;\n      text-decoration: none;\n    }\n    button {\n      font-family: inherit;\n      cursor: pointer;\n      border: none;\n      background: none;\n    }\n    .container {\n      width: 100%;\n      max-width: 1440px;\n      margin: 0 auto;\n    }\n    .section-padding {\n      padding: 160px 80px;\n    }\n    .heading-heavy {\n      font-weight: 800;\n      text-transform: uppercase;\n      letter-spacing: -0.03em;\n    }\n    .btn-primary {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      background-color: transparent;\n      color: var(--primary);\n      border: 1px solid var(--primary);\n      padding: 16px 32px;\n      font-size: 14px;\n      font-weight: 600;\n      text-transform: uppercase;\n      letter-spacing: 0.05em;\n    }\n    .btn-primary.solid {\n      background-color: var(--primary);\n      color: var(--primary-foreground);\n    }\n  </style>\n  <style id=\"navbar-styles\">\n    .navbar {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      z-index: 100;\n      padding: 40px 80px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      color: var(--primary);\n    }\n    .nav-brand {\n      font-size: 24px;\n      font-weight: 900;\n      letter-spacing: -0.05em;\n      text-transform: uppercase;\n    }\n    .nav-links {\n      display: flex;\n      gap: 48px;\n    }\n    .nav-links a {\n      font-size: 12px;\n      font-weight: 600;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n    }\n    .nav-actions {\n      display: flex;\n      gap: 24px;\n      align-items: center;\n    }\n    .nav-icon {\n      width: 24px;\n      height: 24px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n  </style>\n  <style id=\"hero-styles\">\n    .hero {\n      position: relative;\n      width: 100%;\n      height: 900px;\n      min-height: 812px;\n      overflow: hidden;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n    }\n    .hero-bg {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      z-index: 1;\n    }\n    .hero-bg img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n    .hero-overlay {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      background: linear-gradient(180deg, rgba(9,9,11,0.6) 0%, rgba(9,9,11,0.2) 40%, rgba(9,9,11,0.8) 100%);\n      z-index: 2;\n    }\n    .hero-content {\n      position: relative;\n      z-index: 10;\n      max-width: 1000px;\n      padding: 0 40px;\n      margin-top: 80px;\n    }\n    .hero-title {\n      font-size: 120px;\n      line-height: 0.9;\n      margin-bottom: 24px;\n      color: var(--primary);\n    }\n    .hero-subtitle {\n      font-size: 20px;\n      font-weight: 400;\n      color: var(--primary);\n      max-width: 600px;\n      margin: 0 auto 48px;\n      letter-spacing: 0.02em;\n    }\n  </style>\n  <style id=\"manifesto-styles\">\n    .manifesto {\n      background-color: var(--background);\n    }\n    .manifesto-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 120px;\n      align-items: center;\n    }\n    .manifesto-content {\n      padding-right: 40px;\n    }\n    .manifesto-label {\n      font-size: 12px;\n      font-weight: 600;\n      letter-spacing: 0.1em;\n      color: var(--muted-foreground);\n      margin-bottom: 32px;\n      text-transform: uppercase;\n      display: block;\n    }\n    .manifesto-headline {\n      font-size: 56px;\n      line-height: 1.1;\n      margin-bottom: 40px;\n      color: var(--primary);\n    }\n    .manifesto-body {\n      font-size: 18px;\n      line-height: 1.6;\n      color: var(--muted-foreground);\n      margin-bottom: 48px;\n      max-width: 480px;\n    }\n    .manifesto-image {\n      width: 100%;\n      height: auto;\n      aspect-ratio: 3 / 4;\n      background-color: var(--secondary);\n    }\n    .manifesto-image img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n  </style>\n  <style id=\"artifacts-styles\">\n    .artifacts {\n      background-color: var(--background);\n    }\n    .artifacts-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-end;\n      margin-bottom: 80px;\n    }\n    .artifacts-title {\n      font-size: 40px;\n      line-height: 1;\n    }\n    .artifacts-link {\n      font-size: 12px;\n      font-weight: 600;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n      border-bottom: 1px solid var(--primary);\n      padding-bottom: 4px;\n    }\n    .artifacts-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 40px;\n    }\n    .artifact-card {\n      display: flex;\n      flex-direction: column;\n    }\n    .artifact-image-wrapper {\n      width: 100%;\n      aspect-ratio: 4 / 5;\n      background-color: var(--secondary);\n      margin-bottom: 24px;\n      overflow: hidden;\n    }\n    .artifact-image-wrapper img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n    .artifact-meta {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-start;\n    }\n    .artifact-name {\n      font-size: 16px;\n      font-weight: 600;\n      margin-bottom: 8px;\n    }\n    .artifact-category {\n      font-size: 14px;\n      color: var(--muted-foreground);\n    }\n    .artifact-price {\n      font-size: 16px;\n      font-weight: 500;\n    }\n  </style>\n  <style id=\"campaign-styles\">\n    .campaign {\n      background-color: var(--background);\n      padding-bottom: 160px;\n    }\n    .campaign-container {\n      width: 100%;\n      padding: 0 80px;\n    }\n    .campaign-header {\n      margin-bottom: 40px;\n    }\n    .campaign-label {\n      font-size: 12px;\n      font-weight: 600;\n      letter-spacing: 0.1em;\n      color: var(--muted-foreground);\n      margin-bottom: 16px;\n      text-transform: uppercase;\n      display: block;\n    }\n    .campaign-title {\n      font-size: 48px;\n      line-height: 1.1;\n    }\n    .campaign-video-wrapper {\n      width: 100%;\n      aspect-ratio: 21 / 9;\n      background-color: var(--secondary);\n      position: relative;\n      overflow: hidden;\n    }\n    .campaign-video-wrapper img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n    .play-button {\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      width: 80px;\n      height: 80px;\n      border-radius: 50%;\n      background-color: rgba(9, 9, 11, 0.4);\n      backdrop-filter: blur(8px);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      color: var(--primary);\n      border: 1px solid rgba(244, 240, 230, 0.2);\n    }\n  </style>\n</head><body>\n\n  <nav class=\"navbar\">\n    <div class=\"nav-brand\">JAMROCK</div>\n    <div class=\"nav-links\">\n      <a href=\"#\" data-media-type=\"banani-button\">Collections</a>\n      <a href=\"#\" data-media-type=\"banani-button\">Editorial</a>\n      <a href=\"#\" data-media-type=\"banani-button\">Archive</a>\n    </div>\n    <div class=\"nav-actions\">\n      <button class=\"nav-icon\" data-media-type=\"banani-button\">\n        <iconify-icon icon=\"lucide:search\" style=\"font-size: 20px; color: var(--primary)\"></iconify-icon>\n      </button>\n      <button class=\"nav-icon\" data-media-type=\"banani-button\">\n        <iconify-icon icon=\"lucide:user\" style=\"font-size: 20px; color: var(--primary)\"></iconify-icon>\n      </button>\n      <button class=\"nav-icon\" data-media-type=\"banani-button\">\n        <iconify-icon icon=\"lucide:shopping-bag\" style=\"font-size: 20px; color: var(--primary)\"></iconify-icon>\n      </button>\n    </div>\n  </nav>\n\n  <main>\n    <section class=\"hero\">\n      <div class=\"hero-bg\">\n        <img data-aspect-ratio=\"16:9\" data-query=\"cinematic dark moody luxury fashion model wearing black heavy textured apparel, cultural storytelling, 1962 Atlantic LUT, muted neutral tones, 8k resolution, photorealistic, deep blacks cream highlights\" alt=\"Hero cinematic background\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/eecc0b09-7594-4f6a-97eb-3e10b73093b2.jpg\">\n      </div>\n      <div class=\"hero-overlay\"></div>\n      <div class=\"hero-content\">\n        <h1 class=\"hero-title heading-heavy\">NUH APOLOGIES.</h1>\n        <p class=\"hero-subtitle\">The culture, uncompromised. Cinematic storytellers of the diaspora.</p>\n        <button class=\"btn-primary solid\" data-media-type=\"banani-button\">Explore The Archive</button>\n      </div>\n    </section>\n\n    <section class=\"manifesto section-padding container\">\n      <div class=\"manifesto-grid\">\n        <div class=\"manifesto-content\">\n          <span class=\"manifesto-label\">The Manifesto</span>\n          <h2 class=\"manifesto-headline heading-heavy\">We do not dress for holidays. We dress for heritage.</h2>\n          <p class=\"manifesto-body\">\n            Culture isn't a costume you put on once a year. It is a heavy, dignified weight carried daily. Jamrock crafts premium, textured staples that elevate everyday style, drawing from the deep well of diaspora history. No loud tourist tropes. No compromises. Just architectural silhouettes and uncompromising quality.\n          </p>\n          <button class=\"btn-primary\" data-media-type=\"banani-button\">Read The Philosophy</button>\n        </div>\n        <div class=\"manifesto-image\">\n          <img data-aspect-ratio=\"3:4\" data-query=\"medium-format portrait of dignified black model in heavy textured luxury streetwear, powerful posture, muted colors, dark fashion photography, 1962 Atlantic LUT, cream highlights\" alt=\"Manifesto model portrait\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/13623b26-932b-406d-b6a7-7881dae420ee.jpg\">\n        </div>\n      </div>\n    </section>\n\n    <section class=\"artifacts section-padding container\">\n      <div class=\"artifacts-header\">\n        <h2 class=\"artifacts-title heading-heavy\">The Artifacts</h2>\n        <a href=\"#\" class=\"artifacts-link\" data-media-type=\"banani-button\">View Entire Collection</a>\n      </div>\n      <div class=\"artifacts-grid\">\n        <article class=\"artifact-card\" data-media-type=\"banani-button\">\n          <div class=\"artifact-image-wrapper\">\n            <img data-aspect-ratio=\"4:5\" data-query=\"luxury streetwear heavy black jacket, textured, dark studio lighting, muted cream background, high-end editorial fashion photography\" alt=\"The Heavyweight Overshirt\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/c7a4b4a3-fac1-403e-9d18-474344094086.jpg\">\n          </div>\n          <div class=\"artifact-meta\">\n            <div>\n              <h3 class=\"artifact-name\">The Heavyweight Overshirt</h3>\n              <span class=\"artifact-category\">Outerwear / Black Ash</span>\n            </div>\n            <span class=\"artifact-price\">$385</span>\n          </div>\n        </article>\n        <article class=\"artifact-card\" data-media-type=\"banani-button\">\n          <div class=\"artifact-image-wrapper\">\n            <img data-aspect-ratio=\"4:5\" data-query=\"premium luxury streetwear wide leg trousers, heavy texture, dark studio lighting, muted cream background, editorial fashion photography\" alt=\"Architectural Cargo\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/cc6f438a-f4b6-4517-96a4-a398dabb8e81.jpg\">\n          </div>\n          <div class=\"artifact-meta\">\n            <div>\n              <h3 class=\"artifact-name\">Architectural Cargo</h3>\n              <span class=\"artifact-category\">Bottoms / Deep Onyx</span>\n            </div>\n            <span class=\"artifact-price\">$295</span>\n          </div>\n        </article>\n        <article class=\"artifact-card\" data-media-type=\"banani-button\">\n          <div class=\"artifact-image-wrapper\">\n            <img data-aspect-ratio=\"4:5\" data-query=\"luxury streetwear thick structured hoodie, textured heavy cotton, dark studio lighting, muted cream background, editorial fashion photography\" alt=\"Diaspora Pullover\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/e949b687-b993-4d30-9646-d84b7aea8998.jpg\">\n          </div>\n          <div class=\"artifact-meta\">\n            <div>\n              <h3 class=\"artifact-name\">Diaspora Pullover</h3>\n              <span class=\"artifact-category\">Fleece / Bone</span>\n            </div>\n            <span class=\"artifact-price\">$240</span>\n          </div>\n        </article>\n      </div>\n    </section>\n\n    <section class=\"campaign\">\n      <div class=\"campaign-container\">\n        <div class=\"campaign-header\">\n          <span class=\"campaign-label\">Current Campaign</span>\n          <h2 class=\"campaign-title heading-heavy\">Chapter 01: They Carried It</h2>\n        </div>\n        <div class=\"campaign-video-wrapper\" data-media-type=\"banani-button\">\n          <img data-aspect-ratio=\"21:9\" data-query=\"cinematic wide landscape shot of cultural diaspora fashion campaign, models in heavy outerwear, muted luxury tones, film grain, dark and moody, anamorphic lens flare\" alt=\"Campaign Video Thumbnail\" src=\"https://storage.googleapis.com/banani-generated-images/generated-images/126338ae-2bae-4210-9b39-cc3999211341.jpg\">\n          <div class=\"play-button\">\n            <iconify-icon icon=\"lucide:play\" style=\"font-size: 32px; color: var(--primary)\"></iconify-icon>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <!-- Script for Iconify (Icons) -->\n  <script src=\"https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js\"></script>\n\n</body>",
